{
  "functions": {
    "api/modify-resume.ts": {
      "maxDuration": 60,
      "includeFiles": "prompts/**,lib/**"
    },
    "api/ping.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/index.html"
    }
  ]
}
