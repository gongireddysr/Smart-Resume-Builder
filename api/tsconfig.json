{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true
  },
  "include": ["./**/*.ts", "../prompts/**/*.ts", "../src/layer5/**/*.ts", "../src/types/**/*.ts", "../src/utils/validate*.ts", "../src/utils/resumeData.ts"]
}
